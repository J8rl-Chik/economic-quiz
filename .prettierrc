{
  "arrowParens": "avoid",
  "trailingComma": "none",
  "printWidth": 120,
  "singleQuote": true,
  "bracketSpacing": false,
  "tabWidth": 2,
  "jsxBracketSameLine": false,
    "plugins": ["@trivago/prettier-plugin-sort-imports"],
   "importOrder": [
    "<BUILTIN_MODULES>",    
    "<THIRD_PARTY_MODULES>",
    "^@/(.*)$",             
    "^[./]"                 
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true
}
